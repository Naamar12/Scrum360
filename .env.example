# ANTHROPIC_API_KEY: Required for Claude AI API calls.
# Generate one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- JIRA INTEGRATION ---
# Your Jira site domain (e.g., if your URL is https://mycompany.atlassian.net, the domain is 'mycompany')
JIRA_DOMAIN=""

# The email address associated with your Jira account
JIRA_EMAIL=""

# Your Jira API Token. Generate one at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=""

# The IDs of the Jira Boards you want to pull sprint data from, mapped to the Global Filter
JIRA_BOARD_ID_V1="1"
JIRA_BOARD_ID_MAKO3="2"
JIRA_BOARD_ID_N12="3"
JIRA_BOARD_ID_12_SCRUM="4"

# --- SLACK INTEGRATION ---
# Bot token. Required OAuth scopes:
#   channels:history  – read #deployed-versions
#   chat:write        – send messages to channels the bot is a member of
#   chat:write.public – send to public channels without joining (optional)
#   im:write          – open DM conversations to send to @users
# Add these scopes at https://api.slack.com/apps → OAuth & Permissions → Bot Token Scopes,
# then reinstall the app to your workspace to get an updated token.
SLACK_BOT_TOKEN=""